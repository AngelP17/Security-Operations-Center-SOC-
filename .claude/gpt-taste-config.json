{
  "enforcement_mode": "soft",
  "review_threshold": 75,
  "include_patterns": [
    "app/**/*.tsx",
    "app/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.ts",
    "lib/**/*.ts",
    "styles/**/*.css",
    "*.css"
  ],
  "exclude_patterns": [
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.spec.ts",
    "**/__tests__/**",
    "node_modules/**",
    ".next/**",
    "scripts/**"
  ],
  "rules": {
    "hero_max_lines": {
      "enabled": true,
      "max_lines": 3,
      "min_container_width": "max-w-5xl"
    },
    "bento_grid_density": {
      "enabled": true
    },
    "section_spacing": {
      "enabled": true,
      "min_vertical_padding": "py-32"
    },
    "gsap_motion": {
      "enabled": true
    },
    "meta_label_ban": {
      "enabled": true,
      "banned_labels": [
        "SECTION 01",
        "SECTION 02",
        "SECTION 03",
        "SECTION 04",
        "SECTION 05",
        "QUESTION 01",
        "QUESTION 02",
        "QUESTION 03",
        "QUESTION 04",
        "QUESTION 05",
        "ABOUT US",
        "STEP 01",
        "STEP 02",
        "STEP 03",
        "PHASE 01",
        "PHASE 02",
        "PHASE 03"
      ]
    },
    "button_contrast": {
      "enabled": true
    },
    "typography": {
      "enabled": true,
      "approved_fonts": [
        "Satoshi",
        "Cabinet Grotesk",
        "Outfit",
        "Geist"
      ],
      "banned_fonts": [
        "Inter",
        "Arial",
        "Helvetica"
      ]
    },
    "horizontal_scroll_prevention": {
      "enabled": true
    },
    "aida_structure": {
      "enabled": true
    }
  }
}
