# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your Apps > Web App
# Create a new web app if you don't have one

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Optional: Flask Backend URL (for network scanning)
VITE_FLASK_API_URL=http://localhost:5001

# =============================================================================
# GPT-Taste QA Environment Variables
# =============================================================================
# These are used by the design QA gate scripts. For CI/CD, set these as
# GitHub Secrets instead of .env files.

# Required for API review script (CI or local).
# Local runs fall back to static analysis without it.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CI-Only Variables (auto-injected by GitHub Actions, never needed locally):
# GITHUB_TOKEN        - Auto-provided in GitHub Actions workflows
# CHANGED_FILES       - Set automatically by the workflow
# PR_NUMBER           - Set automatically by the workflow  
# REPO                - Set automatically by the workflow
# REVIEW_OUTPUT       - Optional: path to write review JSON (default: ./gpt-taste-review.json)
